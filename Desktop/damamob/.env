# DAMA Mob - Configuration

# 1. Corpus (GCS or Local)
# To use GCS, set these to the bucket URLs.
# To use local files (public folder), leave them blank or set VITE_DAMA_CORPUS_MODE=local
VITE_DAMA_CORPUS_GCS_BASE=
VITE_DAMA_AUD_PUBLIC_BASE=
VITE_DAMA_CORPUS_MODE=local

# 2. Database & Auth (Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 3. Reflection / RAG API (Optional)
VITE_DAMA_API_URL=
VITE_DAMA_USE_LLM=0

# 4. App settings
VITE_DAMA5_ROOT=./
PORT=8031
