# Supabase (Project Settings ‚Üí API)
# Copy this file to `.env.local` and fill in values. `.env.local` is gitignored via `*.local`.

# Teacher audio (local `npm run dev`): pick one ‚Äî restart dev server after changing.
# ‚Ä¢ Leave unset ‚Üí `getCorpusAudSrc` uses `/dama-aud/` ‚Üí files in repo `aud/` (Vite middleware).
# ‚Ä¢ Set below ‚Üí stream from GCS like production ‚Äî test bucket uploads without a Cloud Build/deploy.
# VITE_DAMA_AUD_PUBLIC_BASE=https://storage.googleapis.com/damalight-dama-aud

# Corpus JSON (local `npm run dev`):
# ‚Ä¢ Leave unset ‚Üí `fetchItemFromCorpusFs` uses `/__dama_corpus__/` ‚Üí files in `data/validated-json/` (Vite middleware).
# ‚Ä¢ Set below ‚Üí stream from GCS like production (global `nikaya/index.json` + per-sutta JSON).
#   IMPORTANT: this must be the bucket HTTPS base (no extra path segments).
# VITE_DAMA_CORPUS_GCS_BASE=https://storage.googleapis.com/damalight-dama-json

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: if your dashboard shows a publishable key instead of legacy anon key
# VITE_SUPABASE_PUBLISHABLE_KEY=

# OpenAI (optional, server-only). Enables in-app BuddhaBot reflection answers.
# OPENAI_API_KEY=sk-...
# OPENAI_REFLECTION_MODEL=gpt-4o-mini

# Gemini (optional, server-only). Alternative to OpenAI for in-app BuddhaBot reflection answers.
# GEMINI_API_KEY=...
# GEMINI_REFLECTION_MODEL=gemini-2.5-flash
